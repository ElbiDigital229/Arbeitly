{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f pnpm-lock.yaml yarn.lock'",
    "start": "PORT=${PORT:-5173} BASE_PATH=${BASE_PATH:-/} npm run --workspace @workspace/arbeitly dev",
    "dev": "npm run start",
    "build": "npm run typecheck && npm run --workspaces --if-present build",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run --workspaces --if-present typecheck"
  },
  "private": true,
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "lib/integrations/*",
    "scripts"
  ],
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
